// SBOM 生成を組み込んだ Windows ビルドパイプラインのサンプル
//
// 前提 (Windows エージェント):
//   - Visual Studio 2022 (vcvars64.bat)
//   - Qt 6.11.1 msvc2022_64 (SBOM 同梱)
//   - CMake + ninja
//   - Python 3.11+ と uv (検証ステージで使用。生成自体は素の Python で動く)
//
// ポイント:
//   - bat ステップでは `call` で vcvars64.bat を呼び、環境変数を引き継ぐ
//   - SBOM_BUILD_ID に Jenkins の BUILD_TAG を渡し、DocumentNamespace の
//     一意性をビルドごとに確保する
//   - Qt を更新すると Qt SBOM の SHA1 が変わるが、ExternalDocumentRef の
//     SHA1 は生成時に毎回実ファイルから計算されるため追従する
//   - ★重要: SBOM は「署名後」に生成する。Authenticode 署名は PE 末尾に
//     署名情報を追記しファイルのバイト列を変えるため、成果物のハッシュが
//     署名前後で変わる。SBOM は出荷する実成果物を記述すべきなので、
//     Build -> Sign -> SBOM の順とする。SBOM 生成は ninja の 'sbom'
//     ターゲットではなく生成スクリプト直接呼び出しにして、リビルドで署名が
//     消える可能性を排除する (マニフェストは configure 時に確定済み)。

pipeline {
    agent { label 'windows' }

    environment {
        QT_ROOT  = 'C:/Qt/6.11.1/msvc2022_64'
        CMAKE    = 'C:\\Qt\\Tools\\CMake_64\\bin\\cmake.exe'
        VCVARS   = 'C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\VC\\Auxiliary\\Build\\vcvars64.bat'
        SIGNTOOL = 'C:\\Program Files (x86)\\Windows Kits\\10\\bin\\10.0.26100.0\\x64\\signtool.exe'
        // コード署名証明書 (Jenkins の資格情報から注入する。PFX を使う例)
        SIGN_PFX = credentials('code-signing-pfx')          // Secret file
        SIGN_PWD = credentials('code-signing-pfx-password') // Secret text
        TIMESTAMP_URL = 'http://timestamp.digicert.com'
    }

    stages {
        stage('Configure') {
            steps {
                bat '''
                    call "%VCVARS%"
                    "%CMAKE%" -S . -B build -G Ninja ^
                        -DCMAKE_BUILD_TYPE=Release ^
                        -DCMAKE_PREFIX_PATH=%QT_ROOT% ^
                        -DSBOM_BUILD_ID=%BUILD_TAG%
                '''
            }
        }

        stage('Build') {
            steps {
                bat '''
                    call "%VCVARS%"
                    "%CMAKE%" --build build
                '''
            }
        }

        stage('Sign') {
            steps {
                // 出荷成果物 (EXE/DLL) に Authenticode 署名を付与する。
                // 署名するとファイルのハッシュが変わるため、必ず SBOM 生成より前に実施する。
                bat '''
                    "%SIGNTOOL%" sign /fd SHA256 ^
                        /f "%SIGN_PFX%" /p "%SIGN_PWD%" ^
                        /tr "%TIMESTAMP_URL%" /td SHA256 ^
                        build\\bin\\*.exe build\\bin\\*.dll
                    "%SIGNTOOL%" verify /pa build\\bin\\*.exe build\\bin\\*.dll
                '''
            }
        }

        stage('SBOM') {
            steps {
                // 署名済みバイナリに対して SBOM を生成する。
                // ninja の 'sbom' ターゲットではなく生成スクリプトを直接呼ぶことで、
                // リビルドが走って署名が消える可能性を排除する
                // (sbom_manifest.json は configure 時に確定済み)。
                bat 'python scripts\\generate_sbom.py --manifest build\\sbom_manifest.json --out-dir build\\sbom'
            }
        }

        stage('Validate SBOM') {
            steps {
                // 受領 SBOM を含む全ドキュメントの SPDX 2.3 準拠検証 (公式 spdx-tools)
                bat '''
                    uv sync --frozen
                    for %%f in (vendorlib\\sbom\\*.spdx.json build\\sbom\\*.spdx.json) do (
                        uv run pyspdxtools -i "%%f" || exit /b 1
                    )
                '''
                // 相互参照 (SPDXID / SHA1 / 成果物チェックサム) の整合検証
                bat 'python scripts\\verify_sbom.py --manifest build\\sbom_manifest.json --sbom-dir build\\sbom'
            }
        }

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'build/sbom/*.spdx.json, build/sbom_manifest.json',
                                 fingerprint: true
            }
        }
    }
}
